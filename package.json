{
  "name": "subscriptions-app-remix",
  "type": "module",
  "private": true,
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "build": "NODE_ENV=production remix vite:build",
    "dev": "dotenv -c development npx shopify app dev",
    "generate": "shopify app generate",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "setup": "prisma generate && prisma migrate deploy",
    "db:migrate": "prisma migrate deploy",
    "test": "LC_ALL=en_US.UTF-8 TZ=UTC dotenv -c test vitest",
    "test:ci:buyer-subscriptions": "LC_ALL=en_US.UTF-8 dotenv -c ci vitest extensions/buyer-subscriptions",
    "test:ci:admin-subs-action": "LC_ALL=en_US.UTF-8 dotenv -c ci vitest extensions/admin-subs-action",
    "test:ci:thank-you-page": "LC_ALL=en_US.UTF-8 dotenv -c ci vitest extensions/thank-you-page",
    "type-check": "tsc --project tsconfig.json && tsc --project extensions/buyer-subscriptions/tsconfig.json && tsc --project extensions/admin-subs-action/tsconfig.json",
    "graphql-codegen": "graphql-codegen",
    "graphql-codegen-customer": "graphql-codegen --project shopifyCustomerApi",
    "graphql-codegen-admin-ext": "graphql-codegen --project adminSubsActionExtension"
  },
  "dependencies": {
    "@faker-js/faker": "9.8.0",
    "@google-cloud/storage": "7.16.0",
    "@google-cloud/tasks": "6.1.0",
    "@prisma/client": "6.10.1",
    "@remix-run/css-bundle": "2.16.8",
    "@remix-run/dev": "2.16.8",
    "@remix-run/fs-routes": "2.16.8",
    "@remix-run/node": "2.16.8",
    "@remix-run/react": "2.16.8",
    "@remix-run/route-config": "2.16.8",
    "@remix-run/serve": "2.16.8",
    "@rollup/plugin-graphql": "2.0.5",
    "@rvf/react": "7.1.5",
    "@rvf/remix": "6.3.0",
    "@shopify/address": "4.3.0",
    "@shopify/admin-api-client": "1.1.0",
    "@shopify/app-bridge-react": "4.1.10",
    "@shopify/cli": "3.81.2",
    "@shopify/polaris": "13.9.5",
    "@shopify/shopify-api": "11.13.0",
    "@shopify/shopify-app-remix": "3.8.3",
    "@shopify/shopify-app-session-storage-prisma": "6.0.7",
    "classnames": "2.3.2",
    "cross-env": "7.0.3",
    "graphql": "16.11.0",
    "i18next": "<24.0.0",
    "jsonwebtoken": "9.0.2",
    "lodash": "4.17.21",
    "luxon": "3.6.1",
    "pino": "9.7.0",
    "prisma": "6.10.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "uuid": "11.1.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.7",
    "@remix-run/eslint-config": "2.16.8",
    "@types/node": "24.0.7",
    "@types/react": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.35.0",
    "@typescript-eslint/parser": "8.35.0",
    "@vitejs/plugin-react": "4.6.0",
    "dotenv-cli": "8.0.0",
    "eslint": "9.30.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-react": "7.37.5",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vitest": "3.2.4"
  },
  "resolutions": {
    "graphql": "16.8.1"
  }
}
